{
  "atlassian_account_id": "",
  "jira_base_url": "https://groupondev.atlassian.net",
  "tempo_api_base": "https://api.tempo.io/4",
  "timezone": "Asia/Kolkata",
  "day_start_hour": 8,
  "daily_hours_minimum": 8,
  "min_bucket_minutes": 15,
  "max_entry_minutes": 120,
  "allocation_strategy": "proportional_fill",
  "pto_fallback_ticket": "ADMIN-4",
  "pto_patterns": ["ooo", "out of office", "pto", "vacation", "holiday", "leave"],
  "exploration_tickets": {
    "ai_exploration": {
      "ticket": "SFDC-10142",
      "max_hours_per_day": 1,
      "summary_patterns": ["ai exploration", "skill building", "ai automation", "prompt engineering", "claude exploration", "learning ai", "mcp server"],
      "description": "AI-specific exploration: building Claude skills, exploring AI automation, prompt engineering, MCP tooling"
    },
    "ktlo": {
      "ticket": "SFDC-10198",
      "max_hours_per_day": 1,
      "summary_patterns": ["ktlo", "maintenance", "cleanup", "general exploration", "tooling", "admin chore"],
      "description": "General KTLO / exploration work not tied to a specific feature ticket"
    }
  },
  "on_call": {
    "summary_patterns": ["dev on call", "devoncall", "dev-on-call", "doc", "on-call"],
    "description_patterns": ["dev on call", "devoncall", "doc", "on-call rotation"],
    "min_hours_per_weekday": 1,
    "applies_on": ["Mon", "Tue", "Wed", "Thu", "Fri"]
  },
  "excluded_meeting_patterns": ["focus time", "blocked", "lunch", "break", "ooo", "out of office", "do not book"],
  "skip_declined_meetings": true,
  "skip_tentative_meetings": false,
  "min_meeting_minutes": 15,
  "paths": {
    "mappings": "~/.local/share/meta-tempo-log/meeting-mappings.json",
    "audit": "~/.local/share/meta-tempo-log/audit.csv"
  },
  "keychain": {
    "service": "tempo_api_token",
    "account": ""
  }
}
